# Copiar a `.env` en esta carpeta (`deploy/.env`) antes de `docker compose build`.
# Los puertos por defecto (37891 web, 37892 gastro) son altos para convivir con otros servicios.

# --- URLs públicas ---
# Producción un solo dominio (Next / + Gastro /panel…): ver deploy/nginx-elclavo-gastromanager.conf.example
NEXT_PUBLIC_GASTRO_BASE_URL=https://elclavo.gastromanager.es
# Si antes entraste por IP:puerto, lista legacy para redirigir al dominio (host:puerto, coma-separados):
# GASTRO_LEGACY_HOSTS=203.0.113.10:37892
# Tras Nginx con TLS (obligatorio para cookies/redirects correctos):
TRUST_PROXY=1
AUTH_URL=https://elclavo.gastromanager.es

# Tras HTTPS delante de Gastro: FLASK_SECURE_COOKIES=1
FLASK_SECURE_COOKIES=1

# 1 = mismo FQDN que la web Next (Nginx enruta /panel, /login, /tablet/* a Gastro)
FLASK_MERGED_HOST_ROOT=1

# --- Seguridad ---
# Opcional: Cloudflare Turnstile en el formulario de reserva web (anti-spam). Crea un widget en el dashboard de Cloudflare.
# Tras definirlas: `docker compose build web && docker compose up -d web` (NEXT_PUBLIC_* va en el bundle).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAB...
# TURNSTILE_SECRET_KEY=0x4AAAAAAB...
# NextAuth / sesión tablet (mín. 32 caracteres aleatorios)
AUTH_SECRET=

# Gastro Flask (cookies de sesión del panel)
GASTRO_SECRET_KEY=

# API interna Gastro→Next (carta, estadísticas). Recomendado si solo usas ADMIN_PASSWORD_HASH (sin admin en claro).
# Generar: openssl rand -hex 32
# Si lo dejas vacío, Gastro y Next pueden usar el mismo AUTH_SECRET (ya obligatorio arriba) como enlace interno.
CLAVO_INTERNAL_API_SECRET=

# Gastro→Next en el docker-compose del repo: URL interna fijada a http://web:3000 (no definas
# NEXT_SITE_BASE_URL con 127.0.0.1 ni localhost en el VPS: rompe estadísticas y carta).

# Login /admin en Next: en producción usa hash bcrypt (recomendado).
# Generar hash: node -e "console.log(require('bcryptjs').hashSync('tu_pin',10))"
ADMIN_PASSWORD_HASH=
# Solo para pruebas; en producción deja ADMIN_PASSWORD vacío y usa solo ADMIN_PASSWORD_HASH
ADMIN_PASSWORD=

# --- Opcional: SMTP (Gastro) sin persistir la contraseña en SQLite del panel ---
# Si la defines aquí, Gastro la usa además de la guardada en "Cierre de caja" (útil en Docker).
# CIERRE_CAJA_SMTP_PASSWORD=

# --- Opcional: publicar en otros puertos del host (mapeo host:contenedor) ---
# CLAVO_WEB_PUBLISH=37891
# CLAVO_GASTRO_PUBLISH=37892
