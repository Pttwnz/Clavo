# Ejemplo: elclavo.gastromanager.es → web Next en / ; Gastro en /panel, /login, /tablet/*, etc.
# Copia a sites-available, ajusta certificados y puertos (37891=Next, 37892=Gastro por defecto).
#
# En deploy/.env del VPS:
#   NEXT_PUBLIC_GASTRO_BASE_URL=https://elclavo.gastromanager.es
#   AUTH_URL=https://elclavo.gastromanager.es
#   FLASK_MERGED_HOST_ROOT=1
#   FLASK_SECURE_COOKIES=1
# Luego: docker compose build web && docker compose up -d

# upstream clavo_next { server 127.0.0.1:37891; }
# upstream clavo_gastro { server 127.0.0.1:37892; }
#
# map $http_upgrade $connection_upgrade {
#   default upgrade;
#   '' close;
# }
#
# server {
#   listen 443 ssl http2;
#   server_name elclavo.gastromanager.es;
#   ssl_certificate     /etc/letsencrypt/live/elclavo.gastromanager.es/fullchain.pem;
#   ssl_certificate_key /etc/letsencrypt/live/elclavo.gastromanager.es/privkey.pem;
