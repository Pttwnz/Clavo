#   # --- Next.js (todo lo demás: /, /menu, /ingreso, /recepcion, /admin, /api/auth, …) ---
#   location = /tablet { proxy_pass http://clavo_next; include snippets/proxy-next.conf; }
#   location / {
#     proxy_pass http://clavo_next;
#     include snippets/proxy-next.conf;
#   }
# }
#
# snippets/proxy-gastro.conf (ejemplo):
#   proxy_http_version 1.1;
#   proxy_set_header Host $host;
#   proxy_set_header X-Real-IP $remote_addr;
#   proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#   proxy_set_header X-Forwarded-Proto $scheme;
#
# snippets/proxy-next.conf: mismas cabeceras hacia 37891.
